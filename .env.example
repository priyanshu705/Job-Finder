# ─── Google Sheets ───────────────────────────────
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─── Alerting ────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ALERT_EMAIL=yourgmail@gmail.com
ALERT_EMAIL_PASSWORD=your_gmail_app_password
ALERT_RECEIVER=yourgmail@gmail.com

# ─── Platform Credentials ────────────────────────
INTERNSHALA_EMAIL=you@email.com
INTERNSHALA_PASSWORD=yourpassword

# ─── User Profile ────────────────────────────────
RESUME_PATH=./resumes/resume.pdf
SEARCH_QUERY=python developer
USER_NAME=Your Full Name
USER_PHONE=9876543210
USER_LINKEDIN=https://linkedin.com/in/yourprofile
USER_YEARS_EXP=2
EXPECTED_SALARY=5 LPA
NOTICE_PERIOD=Immediate

# ─── Database ────────────────────────────────────
DATABASE_URL=sqlite:///finder.db

# ─── Local API ────────────────────────────────────
# Safe defaults keep the API on your own machine. Change deliberately if needed.
API_HOST=127.0.0.1
API_PORT=5000
FLASK_DEBUG=0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
